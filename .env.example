# Domains
# Internal hostname suffix — services are reachable as <service>.${INTERNAL_DOMAIN} on the LAN.
INTERNAL_DOMAIN=
# Cloudflare-hosted zone used for the external tunnel hostnames and for the
# delegated ACME challenge that issues the *.${INTERNAL_DOMAIN} wildcard cert.
EXTERNAL_DOMAIN=

# Cloudflare DNS API token used by Traefik's DNS-01 resolver.
# Needs Zone:DNS:Edit on ${EXTERNAL_DOMAIN}.
CLOUDFLARE_DNS_API_TOKEN=

# Cloudflare Tunnel token. Run `terraform output -raw cloudflared_tunnel_token` after apply.
TUNNEL_TOKEN=

# Plex claim token from https://plex.tv/claim — valid ~4 minutes.
PLEX_CLAIM=

# Container runtime defaults.
TZ=Europe/London
PUID=1000
PGID=1000
# Absolute path for application config/state. Keep this outside the repo if you
# want to be able to move or restructure the checkout without moving runtime data.
DATA_ROOT=/path/to/media-center/data

# Terraform variables. Export via `set -a; source .env; set +a` before running terraform.
# The token here needs Account:Cloudflare Tunnel:Edit and Zone:DNS:Edit,
# Zone:WAF:Edit, Zone:Zone Settings:Edit on ${EXTERNAL_DOMAIN}.
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_zone_name=
